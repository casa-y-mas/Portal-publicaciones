generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  supervisor
  editor
}

enum UserStatus {
  active
  inactive
}

enum AccountPlatform {
  instagram
  facebook
}

enum AccountStatus {
  connected
  token_expiring
  disconnected
}

enum ContentType {
  post
  reel
  story
  carousel
}

enum MediaAssetType {
  image
  video
}

enum PostStatus {
  draft
  pending_approval
  scheduled
  cancelled
  published
  failed
}

enum NotificationType {
  failed
  token_expiring
  approval
  success
  system
}

enum LogLevel {
  info
  warning
  error
  success
}

enum InboxPriority {
  high
  medium
  low
}

enum InboxStatus {
  new
  pending
  resolved
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  passwordHash  String?
  role          UserRole
  status        UserStatus      @default(active)
  avatar        String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  createdPosts  ScheduledPost[] @relation("PostCreator")
  approvedPosts ScheduledPost[] @relation("PostApprover")
  mediaAssets   MediaAsset[]    @relation("AssetUploader")
  inboxThreads  SocialInboxThread[] @relation("InboxAssignee")
  inboxNotes    SocialInboxNote[]   @relation("InboxNoteAuthor")
}

model Project {
  id             String          @id @default(cuid())
  name           String          @unique
  color          String
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]
  posts          ScheduledPost[]
  mediaAssets    MediaAsset[]
}

model SocialAccount {
  id               String          @id @default(cuid())
  platform         AccountPlatform
  username         String
  type             String
  status           AccountStatus   @default(connected)
  expiresAt        DateTime?
  projectId        String
  oauthProvider    String?
  oauthState       String?
  accessToken      String?
  refreshToken     String?
  tokenScopes      String?
  tokenLastChecked DateTime?
  connectedAt      DateTime?
  lastError        String?
  pageId           String?
  pageName         String?
  instagramUserId  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inboxThreads     SocialInboxThread[]

  @@index([projectId])
  @@index([oauthProvider])
}

model SocialInboxThread {
  id               String        @id @default(cuid())
  platform         AccountPlatform
  socialAccountId  String
  externalItemId   String
  externalPostId   String?
  accountLabel     String
  authorName       String
  message          String
  priority         InboxPriority @default(medium)
  status           InboxStatus   @default(new)
  occurredAt       DateTime
  assignedToId     String?
  slaDueAt         DateTime?
  firstRespondedAt DateTime?
  resolvedAt       DateTime?
  metadataJson     Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  socialAccount    SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  assignedTo       User?         @relation("InboxAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes            SocialInboxNote[]

  @@unique([socialAccountId, externalItemId])
  @@index([platform])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([occurredAt])
}

model SocialInboxNote {
  id         String            @id @default(cuid())
  threadId   String
  authorId   String
  body       String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  thread     SocialInboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author     User              @relation("InboxNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([authorId])
  @@index([createdAt])
}

model ScheduledPost {
  id             String      @id @default(cuid())
  title          String
  caption        String
  contentType    ContentType
  status         PostStatus
  publishAt      DateTime
  recurrenceJson Json?
  platformsJson  Json
  thumbnail      String?
  projectId      String
  creatorId      String
  approverId     String?
  mediaAssetId   String?
  lastPublishError     String?
  lastPublishDetails   Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator        User        @relation("PostCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  approver       User?       @relation("PostApprover", fields: [approverId], references: [id], onDelete: SetNull)
  mediaAsset     MediaAsset? @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  mediaAssets    ScheduledPostMedia[]

  @@index([projectId])
  @@index([creatorId])
  @@index([approverId])
  @@index([mediaAssetId])
  @@index([status])
  @@index([publishAt])
}

model ScheduledPostMedia {
  id           String        @id @default(cuid())
  postId       String
  mediaAssetId String
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  post         ScheduledPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset    @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([postId, mediaAssetId])
  @@index([postId])
  @@index([mediaAssetId])
}

model MediaAsset {
  id             String          @id @default(cuid())
  fileName       String
  url            String
  mimeType       String
  type           MediaAssetType
  sizeBytes      Int
  tagsJson       Json            @default("[]")
  projectId      String
  uploadedById   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy     User?           @relation("AssetUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  scheduledPosts ScheduledPost[]
  scheduledPostMedia ScheduledPostMedia[]

  @@index([projectId])
  @@index([uploadedById])
  @@index([type])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  href      String?
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([type])
  @@index([read])
  @@index([createdAt])
}

model ActivityLog {
  id         String    @id @default(cuid())
  level      LogLevel
  category   String
  action     String
  targetType String?
  targetId   String?
  summary    String
  detailJson Json?
  createdAt  DateTime  @default(now())

  @@index([level])
  @@index([category])
  @@index([createdAt])
}
